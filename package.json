{
  "name": "aide",
  "version": "0.0.22",
  "description": "AI agent tools CLI for Jira, Azure DevOps, and GitHub",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "bin": {
    "aide": "./src/cli/index.ts"
  },
  "scripts": {
    "dev": "bun run src/cli/index.ts",
    "build": "bun build --compile src/cli/index.ts --outfile dist/aide",
    "build:win": "bun build --compile --target=bun-windows-x64 src/cli/index.ts --outfile dist/aide.exe",
    "build:linux": "bun build --compile --target=bun-linux-x64 src/cli/index.ts --outfile dist/aide-linux",
    "build:mac": "bun build --compile --target=bun-darwin-arm64 src/cli/index.ts --outfile dist/aide-mac",
    "build:all": "bun run build:win && bun run build:linux && bun run build:mac",
    "release": "bun run src/scripts/release.ts",
    "test": "bun test && bun run test:effect",
    "test:bun": "bun test",
    "test:effect": "bunx --bun vitest run",
    "test:all": "bun run test",
    "lint": "oxlint .",
    "lint:fix": "oxlint . --fix",
    "format": "oxfmt . --write",
    "format:check": "oxfmt . --check"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/yargs": "^17.0.35",
    "oxfmt": "^0.56.0",
    "oxlint": "^1.71.0",
    "vitest": "^4.1.9"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "arkregex": "^0.0.5",
    "effect": "^3.21.4",
    "marked": "^16.3.0",
    "valibot": "^1.2.0",
    "yargs": "^18.0.0"
  }
}
